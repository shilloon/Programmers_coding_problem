#include <string>
#include <vector>
#include <cmath>
#include <numeric>

using namespace std;

int solution(string dartResult) {
    
    vector<int> scores;
    
    int i = 0;
    while(i < dartResult.length())
    {
        int score = dartResult[i] - '0';
        if(dartResult[i] == '1' && dartResult[i+1] == '0')
        {
            score = 10;
            i++;
        }
        i++;
        
        char bonus = dartResult[i];
        if(bonus == 'S') score = pow(score, 1);
        else if(bonus == 'D') score = pow(score, 2);
        else if(bonus == 'T') score = pow(score, 3);
        
        scores.push_back(score);
        i++;
        
        if(i < dartResult.length() && (dartResult[i] == '*' || dartResult[i] == '#'))
        {
            char option = dartResult[i];
            int current_idx = scores.size() - 1;
            
            if(option == '*')
            {
                scores[current_idx] *= 2;
                if(current_idx > 0)
                {
                    scores[current_idx - 1] *= 2;
                }
            }
            else if(option == '#')
            {
                scores[current_idx] *= -1;
            }
            i++;
        }
        
    }
    
    int total_score = 0;
    for(int s : scores)
    {
        total_score += s;
    }
    
    return total_score;
}
