#include <string>
#include <vector>
#include <algorithm>

using namespace std;

int get_index(string str)
{
    if(str == "code") return 0;
    if(str == "date") return 1;
    if(str == "maximum") return 2;
    return 3;
}

vector<vector<int>> solution(vector<vector<int>> data, string ext, int val_ext, string sort_by) {
    vector<vector<int>> answer;
    
    int ext_idx = get_index(ext);
    int sort_idx = get_index(sort_by);
    
    for(int i = 0; i < data.size(); i++)
    {
        if(data[i][ext_idx] < val_ext)
        {
            answer.push_back(data[i]);
        }
    }
    
    sort(answer.begin(), answer.end(), [sort_idx](const vector<int>& a, const vector<int>& b)
    {
        return a[sort_idx] < b[sort_idx];         
    });
    
    return answer;
}
