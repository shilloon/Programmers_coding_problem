#include <string>
#include <vector>
#include <algorithm>

using namespace std;

vector<int> solution(vector<int> array, vector<vector<int>> commands) {
    vector<int> answer;
    
    for(int z = 0; z < commands.size(); z++)
    {
        int i = commands[z][0] - 1;
        int j = commands[z][1] - 1;
        int k = commands[z][2] - 1;
        
        vector<int> temp(array.begin() + i, array.begin() + j + 1);
        
        sort(temp.begin(), temp.end());
        
        answer.push_back(temp[k]);
    }
    
    return answer;
}
