#include <string>
#include <vector>
#include <cmath>

using namespace std;

int get_distance(pair<int, int> current, pair<int, int> target)
{
    return abs(current.first - target.first) + abs(current.second - target.second);
}

string solution(vector<int> numbers, string hand) {
    string answer = "";
    
    pair<int, int> left_pos = {3,0};
    pair<int, int> right_pos = {3, 2};
    
    for(int num : numbers)
    {
        if(num == 1 || num == 4 || num == 7)
        {
            answer += "L";
            left_pos = {(num - 1) / 3, (num - 1) % 3};
        }
        else if(num == 3 || num == 6 || num == 9)
        {
            answer += "R";
            right_pos = {(num - 1) / 3, (num - 1) % 3};
        }
        else
        {
            int target_num = (num == 0) ? 11 : num;
            pair<int, int> target_pos = {(target_num - 1) / 3, (target_num - 1) % 3};
            
            int left_dist = get_distance(left_pos, target_pos);
            int right_dist = get_distance(right_pos, target_pos);
            
            if(left_dist < right_dist)
            {
                answer += "L";
                left_pos = target_pos;
            }
            else if(left_dist > right_dist)
            {
                answer += 'R';
                right_pos = target_pos;
            }
            else
            {
                if(hand == "left")
                {
                    answer += "L";
                    left_pos = target_pos;
                }
                else
                {
                    answer += "R";
                    right_pos = target_pos;
                }
            }
        }
    }
    
    return answer;
}
